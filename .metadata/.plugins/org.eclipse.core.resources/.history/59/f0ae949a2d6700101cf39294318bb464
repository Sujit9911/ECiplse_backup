package com.polymorphism;

public class SavingsAccount extends Account {

		 private int withdrawalCount = 0;
		    private  int withdrawalLimit = 3;

		    @Override
		    public void withdraw(double amount) {
		        if (withdrawalCount >= withdrawalLimit) {
		            System.out.println("Withdrawal limit reached");
		            return;
		        }

		        if (amount <= balance) {
		            balance=balance- amount;
		            withdrawalCount++;
		            System.out.println("SavingsAccount Withdrawn: " + amount);
		            System.out.println("Withdrawals this month: " + withdrawalCount);
		        } else {
		            System.out.println("Insufficient funds.");
		        }
		    }
		    
		    public static void main(String[] args) {
		    	SavingsAccount s1= new SavingsAccount();
		    	System.out.println(":::::::Savings Account::::::");
		    	s1.accountHolder="Sujit";
		    	s1.accountNumber=1275;
		    	s1.deposit(100000);
		    	s1.withdraw(500);
		    	s1.displayAccountInfo();
		    	
		    	System.out.println(":::::::Account Account::::::");
		    	CurrentAccount s2=new CurrentAccount();
		    	s2.accountHolder="Sagar";
		    	s2.accountNumber=1255;
		    	s2.deposit(1000);
		    	s2.withdraw(500);
		    	s2.displayAccountInfo();

		    	
		    }
		
	}
